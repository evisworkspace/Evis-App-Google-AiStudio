rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMemberOf(companyId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid)).data.isActive == true;
    }

    function isAdminOf(companyId) {
      return isMemberOf(companyId)
        && (get(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid)).data.role == "owner"
        || get(/databases/$(database)/documents/companies/$(companyId)/users/$(request.auth.uid)).data.role == "admin");
    }

    match /companies/{companyId} {
      allow read: if isMemberOf(companyId);
      allow create: if isSignedIn();
      allow update: if isAdminOf(companyId);
      allow delete: if false;

      match /users/{userId} {
        allow read: if isMemberOf(companyId);
        allow write: if isAdminOf(companyId) || (isSignedIn() && request.auth.uid == userId);
      }

      match /{collection}/{docId} {
        allow read: if isMemberOf(companyId);
        allow create: if isMemberOf(companyId);
        allow update: if isMemberOf(companyId);
        allow delete: if false;
      }

      match /{collection}/{docId}/{subcollection}/{subdocId} {
        allow read: if isMemberOf(companyId);
        allow create: if isMemberOf(companyId);
        allow update: if isMemberOf(companyId);
        allow delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
